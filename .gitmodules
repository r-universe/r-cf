[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "CFtime"]
	path = CFtime
	url = https://github.com/r-cf/cftime
[submodule "geozarr"]
	path = geozarr
	url = https://github.com/r-cf/geozarr
[submodule "ncdfCF"]
	path = ncdfCF
	url = https://github.com/r-cf/ncdfcf
[submodule "zarr"]
	path = zarr
	url = https://github.com/r-cf/zarr
